---
interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "Empresa de sorteos con más de 20 años de trayectoria en Buga, Colombia. Transformamos sueños en realidad con premios increíbles y total transparencia.",
  image = "https://rifasvelez.com/og.image.png",
  canonicalUrl = "https://rifasvelez.com",
} = Astro.props;

import "../styles/global.css";
import Footer from "@components/footer.astro";
import SchemaSEO from "@components/schema-seo.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Essential Meta Tags -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="sorteos, rifas, Buga, premios, Colombia, ventas"
    />
    <meta name="language" content="Spanish" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="googlebot" content="index, follow" />
    <meta name="revisit-after" content="7 days" />
    <meta name="author" content="Velez la Tradicional" />

    <!-- Icons & Manifest -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#EC016D" />

    <!-- Open Graph Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta
      property="og:site_name"
      content="Velez la tradicional de los bugueños"
    />
    <meta property="og:locale" content="es_CO" />

    <!-- Preconnect to external domains -->
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="dns-prefetch" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://www.googletagmanager.com" />

    <!-- SEO Schema Component -->
    <SchemaSEO
      title={title}
      description={description}
      image={image}
      canonicalUrl={canonicalUrl}
    />

    <!-- Google Analytics (via partytown) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-LDL8GLXXE6");

      // Global WhatsApp click tracking
      document.addEventListener("click", (e) => {
        const target = e.target.closest('a[href*="wa.me"]');
        if (target) {
          gtag("event", "whatsapp_contact", {
            event_category: "engagement",
            event_label: "WhatsApp Click",
            link_url: target.href,
          });
        }
      });
    </script>
    <script
      type="text/partytown"
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-LDL8GLXXE6"></script>

    <!-- Preload Animation Manager -->
    <script is:inline>
      document.documentElement.classList.add("preload-texts", "preload-hero");

      // Fallback para conexiones muy lentas (3 segundos máximo)
      const timeout = setTimeout(() => {
        document.documentElement.classList.remove("preload-texts");
        document.documentElement.classList.add("fonts-loaded");
      }, 6000);

      document.fonts.ready.then(() => {
        clearTimeout(timeout);
        if (document.documentElement.classList.contains("preload-texts")) {
          document.documentElement.classList.remove("preload-texts");
          document.documentElement.classList.add("fonts-loaded");
        }
      });
    </script>

    <title>{title} - Velez la Tradicional de los Bugueños</title>
  </head>
  <body class="bg-[#f6f7fa]">
    <slot />
    <Footer />
  </body>
</html>
