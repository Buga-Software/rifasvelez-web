---
interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "Empresa de sorteos con más de 20 años de trayectoria en Buga, Colombia. Transformamos sueños en realidad con premios increíbles y total transparencia.",
  image = "https://rifasvelez.com/og.image.png",
  canonicalUrl = "https://rifasvelez.com",
} = Astro.props;

import "../styles/global.css";
import Footer from "@components/footer.astro";
import SchemaSEO from "@components/schema-seo.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Essential Meta Tags -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="sorteos, rifas, Buga, premios, Colombia, ventas"
    />
    <meta name="language" content="Spanish" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="googlebot" content="index, follow" />
    <meta name="revisit-after" content="7 days" />
    <meta name="author" content="Velez la Tradicional" />

    <!-- Icons & Manifest -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#EC016D" />

    <!-- Open Graph Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta
      property="og:site_name"
      content="Velez la tradicional de los bugueños"
    />
    <meta property="og:locale" content="es_CO" />

    <!-- Preload critical resources -->
    <link
      rel="preload"
      as="image"
      href="/assets/anticipados.webp"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="font"
      href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@400;500;700&display=swap"
    />

    <!-- SEO Schema Component -->
    <SchemaSEO
      title={title}
      description={description}
      image={image}
      canonicalUrl={canonicalUrl}
    />

    <!-- Google Analytics (via partytown) -->
    <script
      type="text/partytown"
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-LDL8GLXXE6"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-LDL8GLXXE6");
    </script>

    <title>{title} - Velez la Tradicional de los Bugueños</title>
  </head>
  <body class="bg-[var(--white-back)]">
    <div class="lg:px-32 px-2 py-5">
      <slot />
    </div>
    <Footer />
  </body>
</html>
