---
import Layout from "@/layouts/layout.astro";
import Nav from "@/components/nav.astro";
import WhatsappIcon from "@/components/icons/WhatsappIcon.astro";
---

<Layout
  title="¡Sé vendedor! - Velez la Tradicional"
  description="Únete a nuestra red de vendedores y genera ingresos de forma flexible. Somos una empresa seria con 20 años en Buga."
  canonicalUrl="https://rifasvelez.com/vendedor"
>
  <Nav />
  
  <main class="min-h-screen bg-gray-50 pb-16 md:pb-24">
    <!-- Hero Section -->
    <section class="relative pt-28 md:pt-36 pb-20 md:pb-32 px-4 md:px-12 bg-[#EC016D] overflow-hidden">
      <!-- Decorative pattern -->
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(white 1px, transparent 1px); background-size: 24px 24px;"></div>
      
      <div class="relative z-10 max-w-4xl mx-auto text-center space-y-4 md:space-y-6">
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-syne font-bold text-white leading-tight tracking-tight drop-shadow-sm">
          ¡Únete a nuestra red de vendedores!
        </h1>
        <p class="font-work-sans text-white/90 text-base md:text-lg lg:text-xl max-w-2xl mx-auto">
          buscamos personas honestas y comprometidas que quieran generar ingresos de forma flexible.
        </p>
      </div>
    </section>

    <!-- Requisitos Section -->
    <section class="max-w-7xl mx-auto px-4 md:px-8 xl:px-12 py-16 md:py-24">
      <div class="text-center mb-16 space-y-6 max-w-3xl mx-auto">
        <div class="inline-flex items-center space-x-2 text-pink-600 font-syne font-bold tracking-widest uppercase text-sm px-6 py-2">
          <span>Requisitos Básicos</span>
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-5xl font-syne font-bold text-gray-900 tracking-tight">
          ¿Qué necesitas para comenzar?
        </h2>
        <p class="font-work-sans text-gray-600 text-lg md:text-xl">
          Es muy sencillo hacer parte de nuestro equipo de ventas. Únete a la familia Vélez.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
        <!-- Card 1 -->
        <div class="bg-white rounded-4xl p-8 shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-transparent hover:border-pink-100 flex flex-col items-center text-center group">
          <div class="w-20 h-20 bg-pink-50 text-pink-500 rounded-3xl flex items-center justify-center mb-6 transition-transform duration-300 group-hover:scale-110 group-hover:bg-pink-100">
            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="font-syne font-bold text-2xl text-gray-900 mb-4">Mayores de Edad</h3>
          <p class="font-work-sans text-gray-600 text-[15px] leading-relaxed">
            Tener <strong>más de 21 años</strong> y disponibilidad para generar ingresos extra a tu ritmo.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="bg-white rounded-4xl p-8 shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-transparent hover:border-pink-100 flex flex-col items-center text-center group">
          <div class="w-20 h-20 bg-pink-50 text-pink-500 rounded-3xl flex items-center justify-center mb-6 transition-transform duration-300 group-hover:scale-110 group-hover:bg-pink-100">
            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="font-syne font-bold text-2xl text-gray-900 mb-4">Hoja de Vida</h3>
          <p class="font-work-sans text-gray-600 text-[15px] leading-relaxed">
            Presentar una <strong>hoja de vida sencilla</strong> en nuestra oficina principal para conocerte.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="bg-white rounded-4xl p-8 shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-transparent hover:border-pink-100 flex flex-col items-center text-center group">
          <div class="w-20 h-20 bg-pink-50 text-pink-500 rounded-3xl flex items-center justify-center mb-6 transition-transform duration-300 group-hover:scale-110 group-hover:bg-pink-100">
            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-syne font-bold text-2xl text-gray-900 mb-4">Comisiones</h3>
          <p class="font-work-sans text-gray-600 text-[15px] leading-relaxed">
            Recibirás la <strong>boletería oficial</strong> y comenzarás a vender con <strong>excelentes comisiones</strong>.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA Section (Matching ganadores.astro) -->
    <section class="py-16 md:py-24 px-4 relative overflow-hidden bg-white text-center rounded-[3rem] shadow-sm max-w-[1400px] mx-auto z-10">
      <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(ellipse_at_center,rgba(233,30,140,0.05)_0%,transparent_70%)]"></div>
      
      <div class="relative z-10 max-w-2xl mx-auto flex flex-col items-center space-y-6 md:space-y-8">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-syne font-bold text-gray-900 leading-tight">
          Gana dinero a tu propio ritmo
        </h2>
        <p class="text-gray-600 font-work-sans text-base md:text-lg">
          Nuestro equipo te explicará en persona todo sobre los pagos, sorteos y beneficios que ofrecemos al hacer parte de la familia Vélez.
        </p>
        
        <div class="mt-4">
          <a
            href="https://wa.me/573169419113?text=Hola,%20estoy%20interesado%20en%20ser%20vendedor"
            target="_blank"
            rel="noopener noreferrer"
            class="primary-button px-9 py-3 gap-2"
          >
            <WhatsappIcon class="size-7" fill="#fff" />
            <span>Quiero ser vendedor</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Espacio Vacío para el Footer (Previene traslape) -->
    <div class="h-[900px] md:h-[400px] w-full pointer-events-none" aria-hidden="true"></div>
  </main>
</Layout>
