---
import Layout from "@/layouts/layout.astro";
import Nav from "@/components/nav.astro";
import WhatsappIcon from "@/components/icons/WhatsappIcon.astro";
import Countdown from "@/components/react/countdown";

// Interfaces
export interface Sorteo {
  img: string;
  alt: string;
  titulo: string;
  descripcion: string[];
  fecha: string;
  mensajeWhatsapp: string;
}

// Datos de los sorteos
export const sorteos: Sorteo[] = [
  {
    img: "https://res.cloudinary.com/dmr7qtfkk/image/upload/v1775249949/premio-mayor_bkmpjl.webp",
    alt: "Sorteo de casa evaluada en 400 millones y otros premios adicionales",
    titulo: "Gran Sorteo Junio 2026",
    descripcion: [
      "PREMIO MAYOR: Casa de $400 millones, ¡libre de impuestos!",
      "Viaje a San Andrés para dos personas (cancelando total).",
      "Incentivos por pago oportuno: Participa por hasta $20 millones adicionales.",
    ],
    fecha: "June 20, 2026 22:30:00",
    mensajeWhatsapp: "Hola, estoy interesado en el gran sorteo de inicio de año",
  },
  {
    img: "https://res.cloudinary.com/dmr7qtfkk/image/upload/v1775393456/Rifa_Motos_2025_vh6vqs.png",
    alt: "Sorteo Motos 2026",
    titulo: "Sorteo Motos 2026",
    descripcion: [
      "Sorteos mensuales (Anticipados) si tienes tu bono al día.",
      "Motos Yamaha Crypton, XTZ150, Aerox, V-strom y Nmax a lo largo de los meses.",
      "Para participar en cada uno, solo debes cumplir la meta de abono mensual.",
    ],
    fecha: "Apr 25, 2026 22:30:00",
    mensajeWhatsapp: "Hola, estoy interesado en el sorteo de las motos",
  }
];
---

<Layout
  title="Sorteos Vigentes - Velez la Tradicional"
  description="Consulta los sorteos activos de Velez con premios increíbles. Participa en nuestras rifas y gana casas, motos, viajes y mucho más."
  canonicalUrl="https://rifasvelez.com/sorteos"
>
  <Nav />
  
  <main class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="relative pt-28 md:pt-36 pb-12 md:pb-32 px-4 md:px-12 bg-[#EC016D] overflow-hidden">
      <!-- Decorative pattern -->
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(white 1px, transparent 1px); background-size: 24px 24px;"></div>
      
      <div class="relative z-10 max-w-4xl mx-auto text-center space-y-4 md:space-y-6">
        
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-syne font-bold text-white leading-tight tracking-tight drop-shadow-sm">
          Sorteos Activos
        </h1>
        
        <p class="font-work-sans text-white/90 text-base md:text-lg lg:text-xl max-w-2xl mx-auto">
          Participa en nuestras rifas y gana casas, motos, viajes y mucho más.
        </p>
      </div>
    </section>

    <!-- Grid de Sorteos -->
    <div class="max-w-7xl mx-auto px-4 md:px-20 grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 mt-10 md:mt-16 text-left relative z-10">
      {sorteos.map((sorteo) => (
        <article class="bg-white rounded-3xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.04)] border border-gray-100 flex flex-col group hover:shadow-[0_30px_70px_rgba(236,1,109,0.1)] transition-all duration-500">
          
          <div class="relative w-full overflow-hidden">
            <img 
              src={sorteo.img} 
              alt={sorteo.alt} 
              class="w-full h-full object-cover"
            />
          </div>

          <!-- MIDDLE: Countdown integrado -->
          <div class="w-full px-6 py-6 md:py-8 bg-gray-50/50 border-b border-gray-100">
            <Countdown targetDate={sorteo.fecha} variant="compact" client:load />
          </div>

          <!-- BOTTOM: Botón de Acción -->
          <div class="p-6 md:p-8 flex flex-col">
            <a 
              href={`https://wa.me/573169419113?text=${encodeURIComponent(sorteo.mensajeWhatsapp)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full flex justify-center items-center gap-3 text-[#25D366] text-base font-semibold hover:opacity-80 transition-opacity"
            >
              <WhatsappIcon class="size-6" fill="#25D366" />
              Contactar por Whatsapp
            </a>
          </div>
        </article>
      ))}
    </div>
    
    <!-- Espacio Vacío para el Footer (Previene traslape) -->
    <div class="h-[900px] md:h-[400px] w-full pointer-events-none" aria-hidden="true"></div>
  </main>
</Layout>
