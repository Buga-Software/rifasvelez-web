---
const response = await fetch(
  "https://res.cloudinary.com/dmr7qtfkk/image/list/v1775409509/ganadores.json",
).catch((e) => null);

let images = [];
if (response && response.ok) {
  const data = await response.json();
  images = data.resources ? data.resources.map((foto: any) => ({
    id: foto.public_id,
    // Eliminamos c_fill,w_800,h_800 para usar el tamaño original
    src: `https://res.cloudinary.com/dmr7qtfkk/image/upload/f_auto,q_auto/v1775409509/${foto.public_id}.${foto.format}`,
    fullSrc: `https://res.cloudinary.com/dmr7qtfkk/image/upload/f_auto,q_auto/v1775409509/${foto.public_id}.${foto.format}`,
    alt: "Feliz Ganador Rifas Vélez"
  })) : [];
}
---

<div class="gallery-container p-4">
  <div class="columns-1 md:columns-2 lg:columns-4 gap-3" id="gallery-grid">
    {images.map((img: any, index: number) => (
      <a
        class="group cursor-zoom-in inline-block w-full mb-3 break-inside-avoid relative overflow-hidden rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 bg-zinc-200 animate-pulse"
        data-fancybox="gallery"
        data-src={img.fullSrc}
        data-caption={img.alt}
      >
        <img 
          class="w-full h-auto block transform transition-opacity duration-500 opacity-0 gallery-img" 
          src={img.src} 
          alt={img.alt} 
          loading={index < 4 ? "eager" : "lazy"}
          onload="this.classList.remove('opacity-0'); this.parentElement.classList.remove('animate-pulse');"
        />
        
        <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      </a>
    ))}
  </div>
</div>

<script>
  import { Fancybox } from '@fancyapps/ui/dist/fancybox/';
  import '@fancyapps/ui/dist/fancybox/fancybox.css';

  // Configuración de Fancybox
  Fancybox.bind('[data-fancybox]', {
    backdropClick: "close",
    Hash: false,
    Thumbs: false,
    styles: {
      container: {
        background: "rgba(0, 0, 0, 0.92)",
      },
    },
  });

  // Asegurar que las imágenes que ya están en caché se muestren si el evento onload no dispara
  document.addEventListener("DOMContentLoaded", () => {
    const imgs = document.querySelectorAll('.gallery-img');
    imgs.forEach((img) => {
      if ((img as HTMLImageElement).complete) {
        img.classList.remove('opacity-0');
        img.parentElement?.classList.remove('animate-pulse');
      }
    });
  });
</script>