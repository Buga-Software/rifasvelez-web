---
// Sanitizes text by escaping special HTML characters to prevent XSS
// when client libraries like Fancybox inject text as HTML
const sanitizeText = (str: string) => {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
};

let images = [];
let errorMessage = null;

try {
  const response = await fetch(
    "https://res.cloudinary.com/dmr7qtfkk/image/list/ganadores.json",
    { cache: 'no-store' } // Avoid cache in SSR environments
  );

  if (!response.ok) {
    throw new Error(`HTTP error! status: ${response.status}`);
  }

  const data = await response.json();
  
  images = data.resources ? data.resources.map((foto: any) => {
    // 1. Validate version (must be numeric, otherwise omit from URL)
    const hasValidVersion = /^\d+$/.test(String(foto.version));
    const versionSegment = hasValidVersion ? `v${foto.version}/` : '';
    
    // 2. Sanitize public_id (prevent path traversal and injection)
    const rawPublicId = String(foto.public_id || '');
    const safePublicId = rawPublicId.replace(/[^a-zA-Z0-9_\-\/]/g, '');
    const encodedPublicId = safePublicId.split('/').map(encodeURIComponent).join('/');

    // 3. Sanitize format (alphanumeric only)
    const rawFormat = String(foto.format || 'jpg');
    const safeFormat = rawFormat.replace(/[^a-zA-Z0-9]/g, '');
    const encodedFormat = encodeURIComponent(safeFormat);

    const baseUrl = `https://res.cloudinary.com/dmr7qtfkk/image/upload/f_auto,q_auto/${versionSegment}${encodedPublicId}.${encodedFormat}`;
    
    // 4. Extract Cloudinary metadata (if it exists) and sanitize against DOM XSS
    const rawCaption = foto.context?.custom?.caption || "Feliz Ganador Rifas Vélez";
    const safeCaption = sanitizeText(rawCaption);

    return {
      id: safePublicId,
      src: baseUrl,
      fullSrc: baseUrl,
      alt: safeCaption
    };
  }) : [];
} catch (error) {
  console.error("[Gallery Error] Failed to fetch or parse Cloudinary images:", error);
  errorMessage = "No pudimos cargar la galería de ganadores en este momento. Por favor, intenta de nuevo más tarde.";
}
---

<div class="gallery-container p-4">
  {errorMessage ? (
    <div class="text-center py-12 bg-red-50 rounded-2xl border border-red-100">
      <p class="text-red-600 font-medium">{errorMessage}</p>
    </div>
  ) : images.length === 0 ? (
    <div class="text-center py-12 bg-zinc-100 rounded-2xl border border-zinc-200">
      <p class="text-zinc-600 font-medium">Aún no hay ganadores para mostrar.</p>
    </div>
  ) : (
    <div class="columns-1 md:columns-2 lg:columns-4 gap-3" id="gallery-grid">
      {images.map((img: any, index: number) => (
        <a
          class="group cursor-zoom-in inline-block w-full mb-3 break-inside-avoid relative overflow-hidden rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 bg-zinc-200 animate-pulse"
          data-fancybox="gallery"
          data-src={img.fullSrc}
          data-caption={img.alt}
        >
          <img 
            class="w-full h-auto block transform transition-opacity duration-500 opacity-0 gallery-img" 
            src={img.src} 
            alt={img.alt} 
            loading={index < 4 ? "eager" : "lazy"}
            onload="this.classList.remove('opacity-0'); this.parentElement.classList.remove('animate-pulse');"
          />
          
          <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
        </a>
      ))}
    </div>
  )}
</div>

<script>
  import { Fancybox } from '@fancyapps/ui/dist/fancybox/';
  import '@fancyapps/ui/dist/fancybox/fancybox.css';

  Fancybox.bind('[data-fancybox]', {
    backdropClick: "close",
    Hash: false,
    Thumbs: false,
    styles: {
      container: {
        background: "rgba(0, 0, 0, 0.92)",
      },
    },
  });

  // Handle already loaded images (browser cache)
  const handleCachedImages = () => {
    const imgs = document.querySelectorAll('.gallery-img');
    imgs.forEach((img) => {
      if ((img as HTMLImageElement).complete) {
        img.classList.remove('opacity-0');
        img.parentElement?.classList.remove('animate-pulse');
      }
    });
  };

  document.addEventListener("DOMContentLoaded", handleCachedImages);
  handleCachedImages();
</script>