<section
  id="proximo-sorteo"
  class="relative pt-12 md:pt-36 pb-24 px-6 md:px-20 overflow-hidden bg-[#f6f7fa] z-10 shadow-t-[0_-20px_50px_rgba(0,0,0,0.3)] rounded-t-4xl"
>
  <div
    class="absolute top-6 left-1/2 -translate-x-1/2 w-24 h-1 bg-gray-300/30 rounded-full"
  >
  </div>

  <div
    class="relative max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-12 lg:gap-20"
  >
    <div
      id="tilt-hitbox"
      class="w-full lg:w-1/2 select-none py-10"
      style="perspective: 1000px;"
    >
      <div
        id="tilt-card"
        class="relative w-full rounded-[2rem] overflow-hidden shadow-[0_20px_50px_rgba(236,72,153,0.15)] ring-1 ring-gray-200 bg-gray-50 transform-gpu will-change-transform"
        style="transform-style: preserve-3d; transition: transform 0.6s ease-out;"
      >
        <img
          src="https://res.cloudinary.com/dmr7qtfkk/image/upload/v1775249949/premio-mayor_bkmpjl.webp"
          alt="Nuestro próximo sorteo"
          class="w-full h-full object-cover"
          loading="lazy"
        />
        <div
          id="tilt-glare"
          class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-white/0 via-white/10 to-white/0 opacity-0 transition-opacity duration-300 mix-blend-overlay"
        >
        </div>
      </div>
    </div>

    <div class="w-full lg:w-1/2 flex flex-col space-y-8">
      <div class="space-y-4">
        <div
          class="inline-flex items-center space-x-2 text-pink-600 font-syne font-bold tracking-widest uppercase text-sm"
        >
          <span class="w-2 h-2 rounded-full bg-pink-500 animate-pulse"></span>
          <span>El Gran Día Se Acerca</span>
        </div>
        <h2
          class="text-5xl md:text-6xl lg:text-7xl font-syne font-bold text-gray-900 leading-[1.1] tracking-tight"
        >
          Nuestro <br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-pink-600"
            >Próximo Sorteo</span
          >
        </h2>
      </div>

      <p
        class="font-work-sans text-lg text-gray-600 max-w-xl text-pretty leading-relaxed"
      >
        Prepárate para cambiar tu vida con nuestro sorteo más espectacular del
        año. Participa ahora y ten la oportunidad de estrenar la casa de tus
        sueños y disfrutarla con toda tu familia.
      </p>

      <div class="grid grid-cols-4 gap-3 py-6 border-y border-gray-200">
        <div class="flex flex-col items-center">
          <span
            id="countdown-days"
            class="text-4xl md:text-5xl font-work-sans font-bold text-gray-900"
            >00</span
          >
          <span
            class="text-[10px] md:text-xs font-work-sans text-gray-500 uppercase mt-2"
            >Días</span
          >
        </div>
        <div class="flex flex-col items-center">
          <span
            id="countdown-hours"
            class="text-4xl md:text-5xl font-work-sans font-bold text-gray-900"
            >00</span
          >
          <span
            class="text-[10px] md:text-xs font-work-sans text-gray-500 uppercase mt-2"
            >Horas</span
          >
        </div>
        <div class="flex flex-col items-center">
          <span
            id="countdown-minutes"
            class="text-4xl md:text-5xl font-work-sans font-bold text-gray-900"
            >00</span
          >
          <span
            class="text-[10px] md:text-xs font-work-sans text-gray-500 uppercase mt-2"
            >Minutos</span
          >
        </div>
        <div class="flex flex-col items-center">
          <span
            id="countdown-seconds"
            class="text-4xl md:text-5xl font-work-sans font-bold text-pink-500"
            >00</span
          >
          <span
            class="text-[10px] md:text-xs font-work-sans text-pink-600 uppercase mt-2"
            >Segundos</span
          >
        </div>
      </div>
    </div>
  </div>
</section>



<script>
  // --- CONTADOR ---
  const targetDate = new Date("June 20, 2026 22:30:00").getTime();
  const updateCountdown = () => {
    const now = Date.now();
    const distance = targetDate - now;
    const get = (id: string) => document.getElementById(id);
    if (distance < 0) return;
    get("countdown-days")!.textContent = Math.floor(distance / 86400000)
      .toString()
      .padStart(2, "0");
    get("countdown-hours")!.textContent = Math.floor(
      (distance % 86400000) / 3600000,
    )
      .toString()
      .padStart(2, "0");
    get("countdown-minutes")!.textContent = Math.floor(
      (distance % 3600000) / 60000,
    )
      .toString()
      .padStart(2, "0");
    get("countdown-seconds")!.textContent = Math.floor(
      (distance % 60000) / 1000,
    )
      .toString()
      .padStart(2, "0");
  };
  updateCountdown();
  setInterval(updateCountdown, 1000);

  // --- EFECTO 3D (sin cambios) ---
  const hitbox = document.getElementById("tilt-hitbox")!;
  const card = document.getElementById("tilt-card")!;
  const glare = document.getElementById("tilt-glare")!;

  hitbox.addEventListener("mousemove", (e) => {
    const rect = hitbox.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    const centerX = rect.width / 2;
    const centerY = rect.height / 2;
    card.style.transition = "transform 0.1s ease-out";
    card.style.transform = `rotateX(${((y - centerY) / centerY) * -19}deg) rotateY(${((x - centerX) / centerX) * 19}deg) scale3d(1.05,1.05,1.05)`;
    glare.style.opacity = "1";
    glare.style.background = `radial-gradient(circle at ${(x / rect.width) * 10}% ${(y / rect.height) * 10}%, rgba(255,255,255,0.4) 0%, transparent 60%)`;
  });

  hitbox.addEventListener("mouseleave", () => {
    card.style.transition = "transform 0.6s ease-out";
    card.style.transform = "rotateX(0deg) rotateY(0deg) scale3d(1,1,1)";
    glare.style.opacity = "0";
  });


</script>

<!-- scroll snap (sin cambios) -->
<script>
  let scrollTimeout: any;
  window.addEventListener(
    "scroll",
    () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const section = document.getElementById("proximo-sorteo");
        if (!section) return;
        const rect = section.getBoundingClientRect();
        const vh = window.innerHeight;
        if (rect.top > 5 && rect.top < vh - 5) {
          rect.top <= vh / 2
            ? section.scrollIntoView({ behavior: "smooth", block: "start" })
            : window.scrollTo({ top: 0, behavior: "smooth" });
        }
      }, 900);
    },
    { passive: true },
  );
</script>
