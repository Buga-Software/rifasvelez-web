---
interface Props {
  title: string;
  description: string;
  image?: string;
  url?: string;
  type?: "website" | "article" | "event";
  canonicalUrl?: string;
}

const {
  title,
  description,
  image = "https://rifasvelez.com/og.image.png",
  url = "https://rifasvelez.com",
  canonicalUrl = "https://rifasvelez.com",
  type = "website",
} = Astro.props;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://rifasvelez.com",
  name: "Vélez la tradicional de los bugueños",
  description:
    "Empresa de sorteos con más de 20 años de trayectoria en Buga, Colombia",
  url: "https://rifasvelez.com",
  telephone: "+573169419113",
  email: "info@rifasvelez.com",
  areaServed: {
    "@type": "City",
    name: "Buga",
    addressCountry: "CO",
  },
  address: {
    "@type": "PostalAddress",
    streetAddress: "Carrera 14 #15-26",
    addressLocality: "Buga",
    addressRegion: "Valle del Cauca",
    postalCode: "76001",
    addressCountry: "CO",
  },
  sameAs: [
    "https://www.facebook.com/velezlatradicional",
    "https://www.instagram.com/velezlatradicional",
  ],
  image: "https://rifasvelez.com/assets/velez.png",
  priceRange: "$$$",
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
    ],
    opens: "09:00",
    closes: "18:00",
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: "https://rifasvelez.com",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: title,
      item: canonicalUrl,
    },
  ],
};
---

<!-- Organization & LocalBusiness Schema -->
<script
  type="application/ld+json"
  set:html={JSON.stringify(organizationSchema)}
/>

<!-- Breadcrumb Schema -->
<script
  type="application/ld+json"
  set:html={JSON.stringify(breadcrumbSchema)}
/>

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />

<!-- Additional Meta Tags -->
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta
  name="apple-mobile-web-app-status-bar-style"
  content="black-translucent"
/>
<meta name="apple-mobile-web-app-title" content="Velez Rifas" />

<!-- Preconnect to improve performance -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" />
<link rel="dns-prefetch" href="https://www.googletagmanager.com" />
<link rel="dns-prefetch" href="https://www.google-analytics.com" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalUrl} />
