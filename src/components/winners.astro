---
const response = await fetch(
  "https://res.cloudinary.com/dmr7qtfkk/image/list/v1775409509/destacado.json",
).catch((e) => null);
let ganadores = [];
if (response && response.ok) {
  const data = await response.json();
  ganadores = data.resources ? data.resources.slice(0, 8) : [];
}
---

<section
  id="ganadores"
  class="relative md:py-32 pt-24 px-6 md:px-20 bg-[#EC016D] overflow-hidden"
>
  <div class="custom-shape-divider-top-1775411143">
    <svg
      data-name="Layer 1"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1200 120"
      preserveAspectRatio="none"
    >
      <path
        d="M600,112.77C268.63,112.77,0,65.52,0,7.23V120H1200V7.23C1200,65.52,931.37,112.77,600,112.77Z"
        class="shape-fill"></path>
    </svg>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto flex flex-col items-center">
    <!-- Encabezado de la Sección -->
    <div class="text-center mb-24 space-y-6 max-w-3xl">
      <div
        class="inline-flex items-center space-x-2 text-white font-syne font-bold tracking-widest uppercase text-sm px-6 py-2"
      >
        <span>Testimonios Reales</span>
      </div>
      <h2
        class="text-5xl md:text-6xl lg:text-7xl font-syne font-bold text-white leading-[1.1] tracking-tight"
      >
        Ellos confiaron y Ganaron
      </h2>
      <p class="font-work-sans text-white text-lg md:text-xl">
        Con más de 20 años de trayectoria, en Rifas Vélez entregamos sueños
        reales. Descubre algunos de los miles de ganadores que hoy disfrutan sus
        premios.
      </p>
    </div>

    <!-- Grid Creativo Estilo Polaroid -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10 w-full px-4"
    >
      {
        ganadores.map((foto: any, index: number) => {
          const rotationClass =
            index % 2 === 0 ? "md:-rotate-2" : "md:rotate-3";

          return (
            <div
              class={`group relative bg-white p-3 pb-6 rounded-[1.5rem] shadow-xl transition-all duration-500 hover:-translate-y-5 hover:rotate-0 hover:z-20 hover:shadow-[0_30px_60px_rgba(236,72,153,0.15)] ${rotationClass}`}
            >
              <div class="relative aspect-square overflow-hidden rounded-xl bg-gray-200">
                <img
                  src={`https://res.cloudinary.com/dmr7qtfkk/image/upload/c_fill,w_600,h_600,f_auto,q_auto/v1775409509/${foto.public_id}.${foto.format}`}
                  alt="Feliz Ganador Rifas Vélez"
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                />
              </div>

              <div class="pt-6 px-2 text-center">
                <h3 class="font-syne font-bold text-zinc-900 text-xl tracking-tight mb-1">
                  Feliz Ganador
                </h3>
                <p class="font-work-sans text-pink-600 font-bold text-xs uppercase tracking-widest">
                  Premio Entregado
                </p>
              </div>
            </div>
          );
        })
      }
    </div>

    <div class="mt-24 text-center">
      <a href="/ganadores" class="secondary-button group gap-2 pl-9 pr-7">
        <span>Ver Galeria Completa</span>
        <img
          src="/icons/arrow-right.svg"
          alt="Arrow Right"
          class="size-4 transition-transform duration-300 group-hover:translate-x-1"
        />
      </a>
    </div>
  </div>

  <div class="md:h-90 h-220 w-full" aria-hidden="true"></div>
</section>

<style>
  .custom-shape-divider-top-1775411143 {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
    transform: rotate(180deg);
    z-index: 1;
  }

  .custom-shape-divider-top-1775411143 svg {
    position: relative;
    display: block;
    width: calc(100% + 1.3px);
    height: 64px;
  }

  .custom-shape-divider-top-1775411143 .shape-fill {
    fill: #f6f7fa;
  }
</style>
